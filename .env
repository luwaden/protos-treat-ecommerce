PORT=5001
NODE_ENV=development

# --- Auth tokens -------------------------------------------------------------
# Generate strong random values, e.g.: openssl rand -hex 32
ACCESS_TOKEN_SECRET=replace-with-a-long-random-string-for-access-tokens
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-string-for-refresh-tokens
REFRESH_TOKEN_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:5173

# --- Redis -------------------------------------------------------------------
# Running locally without Docker:  redis://localhost:6379
# Running via `docker compose up`: redis://redis:6379  (service name, not localhost)
REDIS_URL=redis://localhost:6379

# --- Outgoing email (order confirmations, password reset OTPs) --------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM="Protos Treat <your-email@gmail.com>"

# --- Paystack (test keys — get real ones from your Paystack dashboard) ------
PAYSTACK_SECRET_KEY=sk_test_6fd4e77d284642bc76ca9c8ce0259fb26be04a13
PAYSTACK_PUBLIC_KEY=pk_test_95c2fed7734385bb7940cac6340f794f6cb1d51b

# --- Cloudinary (product image uploads — see IMAGE_UPLOAD_EXPLAINED.md) -----
# Get these from your Cloudinary dashboard: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

BCRYPT_SALT_ROUNDS=12
OTP_EXPIRY_MINUTES=10

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# --- The ONE Admin account, created by `npm run seed` -----------------------
# Change this password before you actually deploy anywhere.
SUPER_ADMIN_EMAIL=admin@protostreat.com
SUPER_ADMIN_PASSWORD=ChangeMe123!

# --- Database (MongoDB, read/written through Prisma) -------------------------
# Running locally without Docker (mongod on your machine, as a replica set):
#   DATABASE_URL="mongodb://localhost:27017/protos_treat?replicaSet=rs0&directConnection=true"
# Running via `docker compose up` (service name, not localhost):
DATABASE_URL="mongodb://localhost:27017/protos_treat?replicaSet=rs0&directConnection=true"
